# Copy only the settings you need into your local environment. Never commit a real token.
HOST=127.0.0.1
PORT=8787
STACKPILOT_WEB_PORT=5173

# Optional web-development override. The Vite proxy defaults to the local Controller on port 8787.
STACKPILOT_API_PROXY_TARGET=http://127.0.0.1:8787

# Required by the Controller. Generate 32 random bytes; never commit the value.
STACKPILOT_MASTER_KEY=
# Production alternative: a systemd credential or Docker secret file. Do not set both forms.
STACKPILOT_MASTER_KEY_FILE=

# SQLite database. Runtime data is ignored by Git.
STACKPILOT_DATABASE_PATH=.stackpilot/stackpilot.sqlite3

# Secure cookies are mandatory outside loopback. Set 0 only for local HTTP development.
STACKPILOT_COOKIE_SECURE=1
STACKPILOT_PRODUCTION=0
STACKPILOT_SESSION_SECONDS=43200

# Exact, comma-separated browser origins. Wildcards and URL paths are rejected.
STACKPILOT_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
# Forwarded headers are honored only from these exact IP/CIDR peers, and never as identity.
STACKPILOT_TRUSTED_PROXIES=

# Dangerous: permits crontab create/update/delete and immediate command execution.
STACKPILOT_ENABLE_CRONTAB_WRITE=0

# Maximum JSON request size in bytes (default: 65536).
STACKPILOT_JSON_BODY_LIMIT_BYTES=65536
STACKPILOT_UPLOAD_ROOT=.stackpilot/uploads
STACKPILOT_UPLOAD_MAX_BYTES=1073741824
STACKPILOT_UPLOAD_CHUNK_MAX_BYTES=8388608

# Optional local-platform collection paths. Use the OS path-list separator.
STACKPILOT_BACKUP_DIRS=

# Dangerous compatibility setting. Leave empty unless the authenticated restart route must be enabled.
STACKPILOT_NODE_RESTART_COMMAND=

# Agent HTTPS listener. It stays disabled until both certificate paths are configured.
STACKPILOT_AGENT_PORT=9443
STACKPILOT_AGENT_HOST=127.0.0.1
STACKPILOT_AGENT_TLS_CERT_PATH=
STACKPILOT_AGENT_TLS_KEY_PATH=
STACKPILOT_AGENT_STATE_PATH=.stackpilot/controller-agent-state.json

# Agent process settings (set only in the Agent process environment).
STACKPILOT_CONTROLLER_URL=https://localhost:9443
STACKPILOT_AGENT_CA_PATH=.stackpilot/dev-certs/controller-cert.pem
STACKPILOT_AGENT_STATE_DIR=.stackpilot/agent
STACKPILOT_AGENT_NAME=
# One-time enrollment token. Leave empty in files; inject it into the first Agent start only.
STACKPILOT_AGENT_ENROLLMENT_TOKEN=
STACKPILOT_AGENT_ENROLLMENT_TOKEN_FILE=
STACKPILOT_AGENT_HEARTBEAT_SECONDS=15
# Development escape hatch only. Production Agents must run as a dedicated non-root user.
STACKPILOT_AGENT_ALLOW_ROOT=0
# Explicit one-start credential rotation; pending state makes retries idempotent.
STACKPILOT_AGENT_ROTATE_CREDENTIAL=0
