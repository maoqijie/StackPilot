# syntax=docker/dockerfile:1.7
FROM node:22.22.0-bookworm-slim AS build
WORKDIR /src
COPY package.json package-lock.json ./
COPY apps apps
COPY packages packages
RUN --mount=type=cache,target=/root/.npm npm ci
RUN npm run build --workspace @stackpilot/controller && npm prune --omit=dev

FROM node:22.22.0-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends tini=0.19.0-1 && rm -rf /var/lib/apt/lists/* && groupadd --system --gid 10001 stackpilot && useradd --system --uid 10001 --gid 10001 --home-dir /var/lib/stackpilot --shell /usr/sbin/nologin stackpilot && mkdir -p /app /var/lib/stackpilot /run/stackpilot && chown -R 10001:10001 /var/lib/stackpilot /run/stackpilot
WORKDIR /app
COPY --from=build --chown=10001:10001 /src/package.json /src/package-lock.json ./
COPY --from=build --chown=10001:10001 /src/node_modules ./node_modules
COPY --from=build --chown=10001:10001 /src/packages/contracts/package.json ./packages/contracts/package.json
COPY --from=build --chown=10001:10001 /src/packages/contracts/dist ./packages/contracts/dist
COPY --from=build --chown=10001:10001 /src/packages/host-telemetry/package.json ./packages/host-telemetry/package.json
COPY --from=build --chown=10001:10001 /src/packages/host-telemetry/dist ./packages/host-telemetry/dist
COPY --from=build --chown=10001:10001 /src/packages/config/package.json ./packages/config/package.json
COPY --from=build --chown=10001:10001 /src/packages/config/src ./packages/config/src
COPY --from=build --chown=10001:10001 /src/apps/controller/package.json ./apps/controller/package.json
COPY --from=build --chown=10001:10001 /src/apps/controller/dist ./apps/controller/dist
USER 10001:10001
ENV NODE_ENV=production HOST=0.0.0.0 PORT=8787 STACKPILOT_PRODUCTION=1 STACKPILOT_DATABASE_PATH=/var/lib/stackpilot/stackpilot.sqlite3
EXPOSE 8787 9443
HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=3 CMD ["node","-e","fetch('http://127.0.0.1:8787/readyz').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"]
ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["node","apps/controller/dist/server.js"]
