# syntax=docker/dockerfile:1.7
FROM node:22.22.0-bookworm-slim@sha256:dd9d21971ec4395903fa6143c2b9267d048ae01ca6d3ea96f16cb30df6187d94 AS build
WORKDIR /src
COPY package.json package-lock.json ./
COPY apps apps
COPY packages packages
RUN --mount=type=cache,target=/root/.npm npm ci
RUN npm run build --workspace @stackpilot/agent && npm prune --omit=dev && mkdir -p /runtime/var/lib/stackpilot-agent

FROM gcr.io/distroless/nodejs22-debian13:nonroot@sha256:773a62fbe24a3f8c8b24b16fd59154627f8b406737bc906f83bf1732bc8907dd
WORKDIR /app
COPY --from=build --chown=10002:10002 /runtime/var/lib/stackpilot-agent /var/lib/stackpilot-agent
COPY --from=build --chown=10002:10002 /src/package.json ./
COPY --from=build --chown=10002:10002 /src/node_modules ./node_modules
COPY --from=build --chown=10002:10002 /src/packages/contracts/package.json ./packages/contracts/package.json
COPY --from=build --chown=10002:10002 /src/packages/contracts/dist ./packages/contracts/dist
COPY --from=build --chown=10002:10002 /src/packages/host-telemetry/package.json ./packages/host-telemetry/package.json
COPY --from=build --chown=10002:10002 /src/packages/host-telemetry/dist ./packages/host-telemetry/dist
COPY --from=build --chown=10002:10002 /src/apps/agent/package.json ./apps/agent/package.json
COPY --from=build --chown=10002:10002 /src/apps/agent/dist ./apps/agent/dist
USER 10002:10002
ENV NODE_ENV=production STACKPILOT_AGENT_STATE_DIR=/var/lib/stackpilot-agent
HEALTHCHECK --interval=60s --timeout=3s --start-period=15s --retries=3 CMD ["/nodejs/bin/node","-e","require('node:fs').accessSync('/var/lib/stackpilot-agent')"]
CMD ["apps/agent/dist/main.js"]
