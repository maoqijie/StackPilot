# syntax=docker/dockerfile:1.7
FROM node:22.22.0-bookworm-slim AS build
WORKDIR /src
COPY package.json package-lock.json ./
COPY apps apps
COPY packages packages
RUN --mount=type=cache,target=/root/.npm npm ci
RUN npm run build --workspace @stackpilot/agent && npm prune --omit=dev

FROM node:22.22.0-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends tini=0.19.0-1+b3 && rm -rf /var/lib/apt/lists/* && groupadd --system --gid 10002 stackpilot-agent && useradd --system --uid 10002 --gid 10002 --home-dir /var/lib/stackpilot-agent --shell /usr/sbin/nologin stackpilot-agent && mkdir -p /app /var/lib/stackpilot-agent && chown -R 10002:10002 /var/lib/stackpilot-agent
WORKDIR /app
COPY --from=build --chown=10002:10002 /src/package.json /src/package-lock.json ./
COPY --from=build --chown=10002:10002 /src/node_modules ./node_modules
COPY --from=build --chown=10002:10002 /src/packages/contracts/package.json ./packages/contracts/package.json
COPY --from=build --chown=10002:10002 /src/packages/contracts/dist ./packages/contracts/dist
COPY --from=build --chown=10002:10002 /src/packages/host-telemetry/package.json ./packages/host-telemetry/package.json
COPY --from=build --chown=10002:10002 /src/packages/host-telemetry/dist ./packages/host-telemetry/dist
COPY --from=build --chown=10002:10002 /src/apps/agent/package.json ./apps/agent/package.json
COPY --from=build --chown=10002:10002 /src/apps/agent/dist ./apps/agent/dist
USER 10002:10002
ENV NODE_ENV=production STACKPILOT_AGENT_STATE_DIR=/var/lib/stackpilot-agent
HEALTHCHECK --interval=60s --timeout=3s --start-period=15s --retries=3 CMD ["node","-e","require('node:fs').accessSync('/var/lib/stackpilot-agent')"]
ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["node","apps/agent/dist/main.js"]
