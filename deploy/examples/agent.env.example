STACKPILOT_CONTROLLER_URL=https://controller.internal.example.invalid:9443
STACKPILOT_AGENT_CA_PATH=/etc/stackpilot-agent/controller-ca.crt
STACKPILOT_AGENT_NAME=replace-with-node-name
STACKPILOT_AGENT_HEARTBEAT_SECONDS=15
STACKPILOT_AGENT_ALLOW_ROOT=0
STACKPILOT_AGENT_ROTATE_CREDENTIAL=0
# Native systemd installs use /run/stackpilot-cert-helper/helper.sock. Docker Agents are inventory-only and cannot renew host certificates.
# Site deployment capabilities remain Controller-denied until an administrator explicitly authorizes the node.
# systemd/Docker inject STACKPILOT_AGENT_ENROLLMENT_TOKEN_FILE as a credential; do not put the token here.
