# Required before the helper reports ready. Use the real StackPilot control-plane domains.
STACKPILOT_CORE_SITE_DOMAINS=
# Optional comma-separated allowlist for systemd start/stop/restart. Inventory and logs remain read-only.
STACKPILOT_SYSTEMD_MANAGED_UNITS=nginx.service,stackpilot-agent.service
STACKPILOT_RUNTIME_CATALOG=/etc/stackpilot-site-helper/runtimes.json
# Optional path overrides are intended for isolated integration tests only.
# STACKPILOT_SITE_HELPER_STATE_ROOT=/var/lib/stackpilot-site-helper
# STACKPILOT_SITE_ROOT=/srv/stackpilot/sites
# STACKPILOT_SITE_NGINX_ROOT=/etc/nginx/conf.d
# STACKPILOT_SITE_ENV_ROOT=/etc/stackpilot-sites
# STACKPILOT_SITE_UNIT_ROOT=/etc/systemd/system
# STACKPILOT_ACME_CHALLENGE_ROOT=/var/lib/letsencrypt/stackpilot-challenges
# STACKPILOT_RUNTIME_ROOT=/opt/stackpilot-runtimes
