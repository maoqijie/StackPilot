STACKPILOT_ALLOWED_ORIGINS=https://stackpilot.example.invalid
STACKPILOT_TRUSTED_PROXIES=127.0.0.1/32
STACKPILOT_PRODUCTION=1
STACKPILOT_COOKIE_SECURE=1
STACKPILOT_AGENT_HOST=10.0.0.10
STACKPILOT_AGENT_PORT=9443
STACKPILOT_ENABLE_CRONTAB_WRITE=0
STACKPILOT_JSON_BODY_LIMIT_BYTES=65536
STACKPILOT_UPLOAD_ROOT=/var/lib/stackpilot-controller/uploads
STACKPILOT_UPLOAD_MAX_BYTES=1073741824
STACKPILOT_UPLOAD_CHUNK_MAX_BYTES=8388608
STACKPILOT_NGINX_CONFIG_DIRS=/etc/nginx/conf.d,/etc/nginx/sites-enabled
# Use LoadCredential/Docker secrets for STACKPILOT_MASTER_KEY_FILE and TLS keys.
