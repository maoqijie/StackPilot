[Unit]
Description=StackPilot Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=stackpilot-agent
Group=stackpilot-agent
WorkingDirectory=/opt/stackpilot-agent/current
Environment=NODE_ENV=production
Environment=STACKPILOT_AGENT_STATE_DIR=/var/lib/stackpilot-agent
Environment=STACKPILOT_AGENT_ENROLLMENT_TOKEN_FILE=%d/agent-enrollment-token
EnvironmentFile=/etc/stackpilot-agent/agent.env
LoadCredential=agent-enrollment-token:/etc/stackpilot-agent/enrollment-token
ExecStart=/usr/bin/node /opt/stackpilot-agent/current/apps/agent/dist/main.js
Restart=on-failure
RestartSec=10s
TimeoutStopSec=30s
StateDirectory=stackpilot-agent
StateDirectoryMode=0700
UMask=0077
NoNewPrivileges=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectSystem=strict
ProtectHome=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
LockPersonality=yes
MemoryDenyWriteExecute=no
ProtectProc=invisible
RemoveIPC=yes
CapabilityBoundingSet=
AmbientCapabilities=
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK
ReadWritePaths=/var/lib/stackpilot-agent

[Install]
WantedBy=multi-user.target
