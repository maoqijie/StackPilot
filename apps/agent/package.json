{
  "name": "@stackpilot/agent",
  "private": true,
  "version": "0.3.0-preview.33",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @stackpilot/host-telemetry",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "npm run build --workspace @stackpilot/host-telemetry && tsc --noEmit",
    "build": "npm run build --workspace @stackpilot/host-telemetry && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "lint": "eslint src",
    "test": "npm run build && npm run build --workspace @stackpilot/cert-helper && node --test ../../tests/agent/*.test.js"
  },
  "dependencies": {
    "@stackpilot/contracts": "0.3.0-preview.33",
    "@stackpilot/host-telemetry": "0.3.0-preview.33",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
