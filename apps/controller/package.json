{
  "name": "@stackpilot/controller",
  "private": true,
  "version": "0.3.0-preview.15",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @stackpilot/host-telemetry",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "npm run build --workspace @stackpilot/host-telemetry && tsc --noEmit",
    "build": "npm run build --workspace @stackpilot/host-telemetry && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc && node -e \"require('node:fs').cpSync('src/database/migrations','dist/database/migrations',{recursive:true})\"",
    "lint": "eslint src",
    "test": "npm run build && node --test ../../tests/controller/*.test.js",
    "db:init": "node dist/cli.js init",
    "db:migrate": "node dist/cli.js migrate",
    "db:import-legacy": "node dist/cli.js import-legacy",
    "db:backup": "node dist/cli.js backup",
    "db:restore": "node dist/cli.js restore",
    "audit:verify": "node dist/cli.js audit-verify",
    "secrets:rotate": "node dist/cli.js secrets-rotate"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@stackpilot/config": "0.3.0-preview.15",
    "@stackpilot/contracts": "0.3.0-preview.15",
    "@stackpilot/host-telemetry": "0.3.0-preview.15",
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
